---
interface Props {
  title: string;
  src: string;
  alt: string;
}

const { title, src, alt } = Astro.props;
---

<section class="my-photo-section">
  <h2>{title}</h2>
  <img src={src} alt={alt} class="profile-image" loading="lazy" />
</section>

<style>
  .my-photo-section {
    text-align: center;

    margin-bottom: var(--spacing-section);
  }

  .my-photo-section h2 {
    margin-bottom: 1.5rem;
  }

  .profile-image {
    max-width: 250px;
    width: 100%;
    border-radius: 50%;
    display: block;
    margin: 0 auto;
    object-fit: cover;
  }
</style>
