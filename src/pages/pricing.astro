---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import TrustBadges from '@sections/pricing/TrustBadges.astro';
import FAQSection from '@sections/content/FAQSection.astro';

import { siteConfig } from '@/config';

const planNames = ['One-time cleanup', 'Security plan', 'Emergency priority cleanup'];

const plans = [
  {
    name: 'One-time cleanup',
    monthlyPrice: null,
    customPrice: '$495',
    description: 'Perfect for fast fix, no recurring commitment.',
    features: [
      'Malware & Virus Removal – Scan and remove all malicious code',
      'Hack Recovery & Restoration – Restore your website to working order.',
      'Broken Login Fix – Regain access to WordPress admin.',
      'Database & File Cleanup – Remove infected or suspicious files safely.',
      'Temporary Security Patch – Close immediate security gaps.',
    ],
    highlighted: false,
    cta: { label: 'Contact', href: '/contact' },
  },
  {
    name: 'Security plan',
    monthlyPrice: 95,
    description: 'Perfect for long-term safety, and peace of mind.',
    features: [
      'Vulnerability Monitoring – Alerts for new threats or outdated components.',
      'Security Audit & Monthly Report – Detailed report on security health.',
      'Website Firewall & Protection – Block attacks before they happen.',
      'Regular Malware Scans – Weekly or daily scans for infections.',
      'Brute-force Protection – Limit failed login attempts, protect admin.',
      'Priority Support – Faster response for urgent issues.',
    ],
    highlighted: true,
    cta: { label: 'Start Now', href: '/contact' },
  },
  {
    name: 'Emergency priority cleanup',
    monthlyPrice: null,
    customPrice: 'Custom',
    description: 'When your website needs immediate rescue.',
    features: [
      '24/7 Priority Response – Immediate attention, anytime.',
      'Full Malware & Virus Removal – Deep scan and cleaning of all files and database.',
      'Website Restoration – Recover from hacks, crashes, or white screens.',
      'Emergency Security Patch – Temporary fixes to prevent further attacks.',
      'Priority Support Call / Video Support – Direct guidance via AnyDesk, TeamViewer, or Zoom.',
    ],
    highlighted: false,
    cta: { label: 'Contact Sales', href: '/contact' },
  },
];

const faqs = [
  {
    question: 'What if my website is severely hacked?',
    answer:
      "Yes, even heavily infected websites can usually be cleaned. If the infection is extremely complex, I'll inform you before proceeding. No hidden surprises.",
  },
  {
    question: 'How long does the cleanup take?',
    answer:
      'Most One-time Cleanups are completed within 24 hours. Emergency Priority Cleanup is handled immediately and often resolved the same day.',
  },
  {
    question: 'Will my website data be safe?',
    answer:
      'Yes. I always create a backup before starting any cleanup work to ensure your data is protected.',
  },
  {
    question: "What's the difference between One-time Cleanup and the Security Plan?",
    answer:
      'One-time Cleanup fixes your current issue. Security Plan protects your website long-term with monitoring, updates, and prevention. If you want peace of mind after cleanup, the Security Plan is recommended.',
  },
  {
    question: 'What if my site gets hacked again?',
    answer:
      "If you're on the Security Plan, ongoing protection reduces the risk significantly. Without a security plan, future hacks would require a new cleanup service.",
  },
  {
    question: 'Do you guarantee your work?',
    answer: 'Yes. I ensure your website is clean and functional before marking the job complete.',
  },
];

const comparisonCategories = [
  {
    name: 'Core Services',
    features: [
      { name: 'Malware Removal', values: [true, true, true] },
      { name: 'Hack Recovery', values: [true, 'Included (if occurs)', true] },
      { name: 'Ongoing Protection', values: [false, true, 'Optional'] },
      { name: 'Regular Malware Scans', values: [false, true, false] },
      { name: 'Firewall Setup', values: [true, true, true] },
    ],
  },
  {
    name: 'Real-time Monitoring',
    features: [
      { name: 'Hacking Attempts Blocking', values: [false, true, false] },
      { name: 'Custom Security Rules', values: [false, true, true] },
      { name: 'API Abuse Protection', values: [false, true, true] },
      { name: 'Bot Event Monitoring', values: [false, true, true] },
      { name: 'Block Unwanted Countries', values: [false, true, false] },
      { name: 'Block Spam Bots', values: [true, true, true] },
      { name: 'Managed Challenge for HTTP1 Users', values: [false, true, false] },
      { name: 'DDoS Protection', values: [true, true, true] },
    ],
  },

  {
    name: 'Support',
    features: [
      { name: 'Email', values: [true, true, true] },
      { name: 'WhatsApp', values: [true, true, true] },
      { name: 'Video Consultation', values: [true, true, true] },
    ],
  },
  {
    name: 'Billing',
    features: [
      { name: 'Bill', values: ['One-time', 'Monthly & Yearly (Your Choice)', 'One-time'] },
    ],
  },
  {
    name: 'Misc',
    features: [
      { name: 'Regular Backups', values: [false, true, false] },
      { name: 'Blacklist Removal', values: [true, true, true] },
    ],
  },
];
---

<MarketingLayout
  title={`Pricing - ${siteConfig.name}`}
  description="Affordable WordPress malware removal and website security plans. Compare one-time cleanup, emergency recovery, and monthly protection services."
>
  <PricingTable
    title="Simple, transparent pricing"
    subtitle="Pick whatever you need. No hidden fees, no surprises."
    plans={plans}
    annualDiscount={25}
    defaultPeriod="monthly"
  />

  <TrustBadges
    guarantee={{
      title: '7-day money-back guarantee',
      description:
        'Try risk-free. Not satisfied? Get a full refund within 7 days, no questions asked.',
    }}
  />

  <ComparisonTable
    title="Compare plans in detail"
    subtitle="See exactly what's included in each plan."
    plans={planNames}
    categories={comparisonCategories}
    highlightedPlan={1}
    background="default"
  />

  <FAQSection
    title="Frequently asked questions"
    faqs={faqs}
    variant="simple"
    background="default"
  />
</MarketingLayout>
