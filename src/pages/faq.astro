---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import { siteConfig } from '@/config';

const faqCategories = [
  {
    name: 'General',
    faqs: [
      {
        question: 'What if my website is severely hacked?',
        answer:
          "Yes, even heavily infected websites can usually be cleaned. If the infection is extremely complex, I'll inform you before proceeding. No hidden surprises.",
      },
      {
        question: 'How long does the cleanup take?',
        answer:
          'Most One-time Cleanups are completed within 24 hours. Emergency Priority Cleanup is handled immediately and often resolved the same day.',
      },
      {
        question: 'Will my website data be safe?',
        answer:
          'Yes. I always create a backup before starting any cleanup work to ensure your data is protected.',
      },
    ],
  },
  {
    name: 'Technical',
    faqs: [
      {
        question: 'What if my site gets hacked again?',
        answer:
          "If you're on the Security Plan, ongoing protection reduces the risk significantly. Without a security plan, future hacks would require a new cleanup service.",
      },
      {
        question: 'Do you guarantee your work?',
        answer:
          'Yes. I ensure your website is clean and functional before marking the job complete.',
      },
      {
        question: 'How quickly can you fix my hacked WordPress website?',
        answer:
          'In most cases, I start working within minutes of confirmation. Basic malware infections and common issues can often be cleaned within a few hours. More complex hacks may take longer depending on severity, but I always provide a clear timeline after initial review.',
      },
      {
        question: 'Will my website data be safe during the cleanup process?',
        answer:
          'Yes. I always create a full backup before starting any recovery work. Your database, media files, and content are preserved. The goal is to remove malware and vulnerabilities without affecting your existing website content.',
      },
    ],
  },
  {
    name: 'Misc',
    faqs: [
      {
        question: 'How do we work together during the repair process?',
        answer:
          'After you contact me, I will request temporary access (hosting, cPanel, or WordPress admin). I can also assist via live support using screen-sharing tools if needed. Once the issue is resolved, I provide a report explaining what was fixed and how to prevent future problems.',
      },
      {
        question: "What's the difference between One-time Cleanup and the Security Plan?",
        answer:
          'One-time Cleanup fixes your current issue. Security Plan protects your website long-term with monitoring, updates, and prevention. If you want peace of mind after cleanup, the Security Plan is recommended.',
      },
    ],
  },
];
---

<MarketingLayout
  title={`FAQ - ${siteConfig.name}`}
  description={`Frequently asked questions about ${siteConfig.name}. Find answers about pricing, features, security, and more.`}
>
  <PageHeader
    title="Frequently Asked Questions"
    subtitle={`Everything you need to know about my service. Can't find what you're looking for?`}
  >
    <a href="/contact" class="text-primary hover:underline">Contact me</a>.
  </PageHeader>

  <FAQSection categories={faqCategories} variant="accordion" background="default" />
</MarketingLayout>
