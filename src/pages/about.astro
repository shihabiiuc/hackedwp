---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import VideoEmbed from '@sections/content/VideoEmbed.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import { siteConfig } from '@/config';

const values = [
  {
    title: 'Expertise You Can Trust',
    description:
      'With over 10 years of WordPress experience, I handle every hack, error, or malware issue with proven skill and care.',
  },
  {
    title: 'Manual, Thorough Approach',
    description:
      "I don't rely on automated tools. Every cleanup and security check is done manually to ensure nothing is missed.",
  },
  {
    title: 'Fast Response',
    description:
      'Time is critical when your site is down. I respond quickly and work efficiently to get your site back online without unnecessary delays.',
  },
  {
    title: 'Long-Term Security',
    description:
      "I don't just fix the immediate problem. I strengthen your WordPress site to prevent future hacks and keep your online presence safe.",
  },
];

const stats = [
  { value: '10+', label: 'Years experience' },
  { value: '200+', label: 'Projects completed' },
  { value: '100%', label: 'Success score' },
  { value: '14%', label: 'World domination' },
];
---

<MarketingLayout
  title={`About - ${siteConfig.name}`}
  description="I'm a WordPress expert with 10+ years of experience in hacked site recovery, malware cleanup, and security. Fast, manual, and reliable service to get your website back online safely."
>
  <PageHeader title="I'm securing the future of your online presence" align="left" maxWidth="lg">
    <p class="mt-6 text-lg text-text-muted leading-relaxed">
      I specialize exclusively in WordPress website recovery and security. With 10+ years of
      hands-on experience, I help website owners <strong
        >regain control of their sites after hacks</strong
      >, malware attacks, or errors. I don't rely on automated tools — every cleanup is manual and
      thorough, so your website is restored safely and securely.
    </p>
    <p class="mt-4 text-lg text-text-muted leading-relaxed">
      Fast response is my promise. I understand the urgency of a hacked website, and I act
      immediately so you can get back online without unnecessary downtime.
    </p>
  </PageHeader>

  <StatsSection stats={stats} background="muted" />

  <VideoEmbed
    title="Client feedback"
    subtitle="Watch what my clients say about my services. Real feedback from real website owners I've helped."
    videoId="OoUzIzB5XWw"
    provider="youtube"
    maxWidth="lg"
    background="default"
  />

  <ValuesSection title="My values" items={values} variant="card" columns={2} background="default" />
</MarketingLayout>
