---
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import MyPhoto from '@sections/marketing/MyPhoto.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import { siteConfig } from '@/config';
import IntegrationsGrid from '@sections/marketing/IntegrationsGrid.astro';

type TestimonialEntry = CollectionEntry<'testimonials'>;

const testimonials = await getCollection(
  'testimonials',
  ({ data }: { data: TestimonialEntry['data'] }) => !data.draft
);
const sortedTestimonials = [...testimonials].sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order
);

const integrations = [
  {
    name: 'Video Calling',
    logo: '/images/integrations/video-calling.svg',
    featured: true,
    description: 'Real time talking in video calls and screen sharing on Google Meet or Zoom.',
  },
  {
    name: 'Remote Computing',
    logo: '/images/integrations/remote-computing.svg',
    category: 'Communication',
    featured: true,
    description:
      'AnyDesk or TeamViewer allows me to operate your computer in real time. It really helps when needed.',
  },
  {
    name: 'Escrow Platform',
    logo: '/images/integrations/escrow.svg',
    featured: true,
    description:
      'This is our first-time working together and we do not fully believe each other yet. So getting a service and paying for it becomes more easy when we use platforms like Upwork, Fiverr, etc.',
  },
];

const featuredIntegrations = integrations.filter((i) => i.featured);
---

<MarketingLayout
  title={`${siteConfig.name} - ${siteConfig.description}`}
  description={siteConfig.description}
>
  <Hero
    title="I Recover Hacked WordPress Websites — Fast."
    subtitle="Emergency WordPress recovery, malware cleanup, and server troubleshooting without guesswork. Freelance web developer helping critical website owners."
    primaryCTA={{ label: 'Get Emergency Help', href: '/contact' }}
    secondaryCTA={{
      label: 'Watch Client Feedback',
      href: 'https://www.youtube.com/playlist?list=PL4TTPpW1BUuxEFuMDIwapKRYJTxE2mm_n',
    }}
  />
  <MyPhoto
    title="10+ Years experience. Trusted by 100+ clients worldwide"
    src="/images/team/shihab.jpg"
    alt="Shihab Ul Hoque"
  />

  <HowItWorks
    title="How it works?"
    subtitle="Three simple steps to get your website back in the earliest time possible."
    steps={[
      {
        title: 'Contact & Explain',
        description:
          'Reach out to me by any one of the channels you see in the contact page, tell me your domain name (URL), and when it was hacked.',
        icon: 'lucide:bike',
      },
      {
        title: 'Fixed Price Quote',
        description:
          'After you contacting, I will analyze your website using my tools and give you a fixed price quote.',
        icon: 'lucide:receipt',
      },
      {
        title: 'Get Your Website Back',
        description:
          'I will recover your website, fix hacking related errors, block the vulnarable backdoors, ensure proper security, and give you a backup.',
        icon: 'lucide:refresh-ccw-dot',
      },
    ]}
    variant="horizontal"
    background="muted"
  />

  <IntegrationsGrid
    title="Support channels"
    subtitle="Some of you may need immediate head to head discussion. So I can offer you the following support channels if required - no matter where do you live!"
    integrations={featuredIntegrations}
    variant="detailed"
    invertOnDark={false}
    columns={3}
    background="default"
    footerLink={{ label: 'Contact me now →', href: '/contact' }}
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="Trusted by website owners worldwide"
        subtitle="100+ big clients went through my service since 2016."
        background="muted"
        limit={4}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }
</MarketingLayout>
